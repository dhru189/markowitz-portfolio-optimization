    "## 7. Real-World Constraints\n\n",
    "Raw Markowitz often produces extreme, impractical portfolios. In practice, quant portfolio managers add constraints.\n",
    "CVXPY makes adding constraints trivial \u2014 just append to the constraints list."
   ],
   "id": "cell-md-constraints"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# \u2500\u2500 Sector indices \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "tech_idx   = np.array([ASSETS.index(t) for t in ['AAPL','MSFT','GOOGL']])\n",
    "fin_idx    = np.array([ASSETS.index(t) for t in ['JPM','GS']])\n",
    "health_idx = np.array([ASSETS.index(t) for t in ['JNJ','PFE']])\n",
    "energy_idx = np.array([ASSETS.index(t) for t in ['XOM','CVX']])\n",
    "\n",
    "sector_caps = {\n",
    "    'Technology': (tech_idx,   0.40),  # max 40% in tech\n",
    "    'Financials': (fin_idx,    0.30),  # max 30% in financials\n",
    "    'Healthcare': (health_idx, 0.30),  # max 30% in healthcare\n",
    "    'Energy':     (energy_idx, 0.25),  # max 25% in energy\n",
    "}\n",
    "\n",
    "# \u2500\u2500 Solve with all constraints \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "constrained = solve_portfolio(\n",
    "    mu_np, Sigma_np,\n",
    "    long_only   = True,\n",
    "    max_weight  = 0.25,       # no single stock > 25%\n",
    "    sector_caps = sector_caps,\n",
    ")\n",
    "\n",
    "print('=' * 55)\n",
    "print('  CONSTRAINED PORTFOLIO')\n",
    "print('  (long-only, max 25% per stock, sector caps)')\n",
    "print('=' * 55)\n",
    "print(f\"  Expected Return : {constrained['return']*100:.2f}% p.a.\")\n",
    "print(f\"  Volatility      : {constrained['volatility']*100:.2f}% p.a.\")\n",
    "print(f\"  Sharpe Ratio    : {constrained['sharpe']:.4f}\")\n",
    "print()\n",
    "print('  Asset Weights:')\n",
    "for asset, w in sorted(zip(ASSETS, constrained['weights']), key=lambda x: -x[1]):\n",
    "    bar = '\u2588' * int(w * 40)\n",
    "    sector = TICKERS[asset]\n",
    "    print(f\"  {asset:6s}  [{sector:12s}]  {w*100:6.2f}%  {bar}\")"
   ],
   "id": "cell-constrained"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Portfolio Comparison Summary"
   ],
   "id": "cell-md-summary"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# \u2500\u2500 Equal weight benchmark \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "ew = np.ones(n) / n\n",
    "ew_ret = float(mu_np @ ew)\n",
    "ew_vol = float(np.sqrt(ew @ Sigma_np @ ew))\n",
    "ew_sharpe = (ew_ret - 0.05) / ew_vol\n",
    "\n",
    "# \u2500\u2500 Summary Table \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\n",
    "summary = pd.DataFrame({\n",
    "    'Portfolio': [\n",
    "        'Equal Weight (1/N)',\n",
    "        'Minimum Variance',\n",
    "        'Maximum Sharpe',\n",
    "        'Constrained (Real-World)',\n",
    "    ],\n",
    "    'Return (%)': [\n",
    "        ew_ret*100,\n",
    "        min_var['return']*100,\n",
    "        max_sharpe['return']*100,\n",
    "        constrained['return']*100,\n",
    "    ],\n",
    "    'Volatility (%)': [\n",
    "        ew_vol*100,\n",
    "        min_var['volatility']*100,\n",
    "        max_sharpe['volatility']*100,\n",
    "        constrained['volatility']*100,\n",
    "    ],\n",
    "    'Sharpe Ratio': [\n",
    "        ew_sharpe,\n",
    "        min_var['sharpe'],\n",
    "        max_sharpe['sharpe'],\n",
    "        constrained['sharpe'],\n",
    "    ]\n",
    "})\n",
    "\n",
    "summary = summary.set_index('Portfolio').round(4)\n",
    "print('\\nPortfolio Comparison Summary')\n",
    "print('=' * 60)\n",
    "print(summary.to_string())\n",
    "print()\n",
    "print('Key Takeaway: CVXPY makes it trivial to add or remove constraints')\n",
    "print('while the optimizer handles all the heavy lifting \u2014 exactly how')\n",
    "print('quant portfolio managers use it in production.')"
   ],
   "id": "cell-summary"
  },
